Name:           corridorkey-resolve-ofx
Version:        @VERSION@
Release:        1%{?dist}
Summary:        CorridorKey OpenFX plugin for DaVinci Resolve Studio (experimental Linux RTX track)

License:        CC-BY-NC-SA-4.0
URL:            https://github.com/alexandremendoncaalvaro/CorridorKey-Runtime
BuildArch:      x86_64

# The plugin's own ELF dependencies are satisfied from sibling .so files
# shipped inside /usr/OFX/Plugins/CorridorKey.ofx.bundle/Contents/Linux-x86_64/
# via $ORIGIN rpath. Automatic dependency discovery would add false
# requirements on libraries that are already bundled, so we disable it.
AutoReqProv:    no

Requires:       /bin/sh
Requires:       glibc

%description
CorridorKey is a chroma-key OpenFX plugin that accelerates real-time green-
and blue-screen keying on NVIDIA RTX GPUs. This package installs the plugin
under /usr/OFX/Plugins/ and exposes the corridorkey CLI on PATH via
/usr/local/bin. DaVinci Resolve Studio 20 is required; the free Resolve
edition does not load OpenFX plugins on Linux. A proprietary NVIDIA driver
555 or newer is required.

%install
rm -rf %{buildroot}
mkdir -p %{buildroot}
cp -R %{_payload_dir}/* %{buildroot}/

%files
/usr/OFX/Plugins/CorridorKey.ofx.bundle

%post
# Register the CorridorKey CLI on PATH via a symlink under /usr/local/bin,
# matching the Debian postinst behaviour and the Windows installer PATH
# registration.
CLI_PATH=/usr/OFX/Plugins/CorridorKey.ofx.bundle/Contents/Linux-x86_64/corridorkey
if [ -x "$CLI_PATH" ]; then
    ln -snf "$CLI_PATH" /usr/local/bin/corridorkey
fi
exit 0

%preun
# Only the last uninstall (argument 0) removes the symlink, so upgrades do
# not flap the link off and back on.
if [ "$1" = "0" ] && [ -L /usr/local/bin/corridorkey ]; then
    target=$(readlink -f /usr/local/bin/corridorkey || true)
    case "$target" in
        /usr/OFX/Plugins/CorridorKey.ofx.bundle/*)
            rm -f /usr/local/bin/corridorkey
            ;;
    esac
fi
exit 0
