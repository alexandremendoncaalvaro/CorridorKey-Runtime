{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "shell:allow-execute",
    "fs:allow-read",
    "fs:allow-write",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "args": true,
          "sidecar": true,
          "name": "binaries/ck-engine"
        }
      ]
    },
    {
      "identifier": "fs:allow-read",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-write",
      "allow": [{ "path": "**" }]
    }
  ]
}
