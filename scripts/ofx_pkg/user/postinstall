#!/bin/bash
set -euo pipefail

console_user="$(stat -f%Su /dev/console)"
if [ -z "$console_user" ] || [ "$console_user" = "root" ]; then
    exit 0
fi

user_home="$(dscl . -read "/Users/$console_user" NFSHomeDirectory | awk '{print $2}')"
if [ -z "$user_home" ]; then
    exit 0
fi

system_bundle="/Library/OFX/Plugins/CorridorKey.ofx.bundle"
target_dir="${user_home}/Library/OFX/Plugins"
target_bundle="${target_dir}/CorridorKey.ofx.bundle"

if [ ! -d "$system_bundle" ]; then
    exit 0
fi

mkdir -p "$target_dir"
ditto "$system_bundle" "$target_bundle"
chown -R "$console_user" "$target_bundle"
rm -rf "$system_bundle"
