#!/bin/bash
set -euo pipefail

console_user="$(stat -f%Su /dev/console)"
if [ -z "$console_user" ] || [ "$console_user" = "root" ]; then
    exit 0
fi

user_home="$(dscl . -read "/Users/$console_user" NFSHomeDirectory | awk '{print $2}')"
if [ -z "$user_home" ]; then
    exit 0
fi

cache_paths=(
    "${user_home}/Library/Application Support/Blackmagic Design/DaVinci Resolve/Support/OFXPluginCacheV2.xml"
    "${user_home}/Library/Containers/com.blackmagic-design.DaVinciResolve/Data/Library/Application Support/OFXPluginCacheV2.xml"
    "${user_home}/Library/Containers/com.blackmagic-design.DaVinciResolveLite/Data/Library/Application Support/OFXPluginCacheV2.xml"
    "${user_home}/Library/Containers/com.blackmagic-design.DaVinciResolveStudio/Data/Library/Application Support/OFXPluginCacheV2.xml"
)

for cache_path in "${cache_paths[@]}"; do
    rm -f "$cache_path"
done
