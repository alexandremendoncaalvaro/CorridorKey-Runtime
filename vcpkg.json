{
    "$comment": "CorridorKey Runtime — High-Performance C++ Inference Engine",
    "name": "corridorkey-runtime",
    "version-string": "0.1.0",
    "dependencies": [
        {
            "name": "onnxruntime",
            "platform": "!osx",
            "features": [
                "directml"
            ],
            "$comment": "Primary ML inference engine (Vendored on macOS for CoreML, DML on Windows)"
        },
        {
            "name": "openexr",
            "$comment": "VFX-standard 16/32-bit linear float image format"
        },
        {
            "name": "libpng",
            "$comment": "8/16-bit PNG image support"
        },
        {
            "name": "ffmpeg",
            "features": [
                "avcodec",
                "avformat",
                "swscale",
                "swresample"
            ],
            "$comment": "Video decode/encode with basic VFX-friendly features"
        },
        {
            "name": "catch2",
            "version>=": "3.5.0",
            "$comment": "Modern testing framework (v3)"
        },
        {
            "name": "cxxopts",
            "$comment": "Lightweight CLI argument parser"
        },
        {
            "name": "cpr",
            "$comment": "C++ Requests for downloading models"
        }
    ]
}
