{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 28,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default (vcpkg toolchain)",
            "description": "Base configuration for all presets",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
            "environment": {
                "MACOSX_DEPLOYMENT_TARGET": "14.0",
                "VCPKG_OSX_DEPLOYMENT_TARGET": "14.0"
            },
            "cacheVariables": {
                "VCPKG_MANIFEST_MODE": "ON",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "macos-portable",
            "displayName": "macOS Portable Base",
            "description": "Base configuration for portable macOS release builds",
            "hidden": true,
            "inherits": "default",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "environment": {
                "MACOSX_DEPLOYMENT_TARGET": "14.0",
                "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/scripts/vcpkg-triplets"
            },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "corridorkey-arm64-osx"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug (ASAN)",
            "description": "Debug build with AddressSanitizer enabled",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ENABLE_ASAN": "ON"
            }
        },
        {
            "name": "debug-macos-portable",
            "displayName": "Debug macOS Portable",
            "description": "Debug build with portable macOS deployment target",
            "inherits": [
                "debug",
                "macos-portable"
            ]
        },
        {
            "name": "release",
            "displayName": "Release (Optimized)",
            "description": "Release build with maximum optimizations",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "release-macos-portable",
            "displayName": "Release macOS Portable",
            "description": "Release build with portable macOS deployment target",
            "inherits": [
                "release",
                "macos-portable"
            ]
        },
        {
            "name": "release-lto",
            "displayName": "Release + LTO",
            "description": "Release build with Link-Time Optimization for cross-file inlining",
            "inherits": "release",
            "cacheVariables": {
                "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "debug-macos-portable",
            "configurePreset": "debug-macos-portable"
        },
        {
            "name": "release",
            "configurePreset": "release"
        },
        {
            "name": "release-macos-portable",
            "configurePreset": "release-macos-portable"
        },
        {
            "name": "release-lto",
            "configurePreset": "release-lto"
        }
    ],
    "testPresets": [
        {
            "name": "unit",
            "configurePreset": "debug",
            "output": {
                "outputOnFailure": true
            },
            "filter": {
                "include": {
                    "name": "unit"
                }
            }
        }
    ]
}
