# Enforce LF line endings on POSIX shell scripts and CMake configuration files
# so they stay executable on Linux/macOS hosts when checked out on Windows.
*.sh text eol=lf
*.bash text eol=lf
scripts/vcpkg-triplets/*.cmake text eol=lf
packaging/linux/deb/control.in text eol=lf
packaging/linux/deb/postinst text eol=lf
packaging/linux/deb/prerm text eol=lf
packaging/linux/rpm/*.spec.in text eol=lf

# Keep Windows-native scripts as CRLF.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

assets/video_samples/*.mp4 filter=lfs diff=lfs merge=lfs -text
assets/image_samples/**/*.png filter=lfs diff=lfs merge=lfs -text
assets/image_samples/**/*.jpg filter=lfs diff=lfs merge=lfs -text
assets/image_samples/**/*.exr filter=lfs diff=lfs merge=lfs -text
models/*.pth filter=lfs diff=lfs merge=lfs -text
models/*.onnx filter=lfs diff=lfs merge=lfs -text
models/*.safetensors filter=lfs diff=lfs merge=lfs -text
models/*.mlxfn filter=lfs diff=lfs merge=lfs -text
