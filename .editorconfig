# EditorConfig — consistent formatting across IDEs for all contributors
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{hpp,cpp,h,c}]
indent_size = 4
max_line_length = 100

[*.{yml,yaml}]
indent_size = 2

[*.{json,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[CMakeLists.txt]
indent_size = 4

[*.cmake]
indent_size = 4

[Makefile]
indent_style = tab

[*.{ps1,psm1}]
indent_size = 4
end_of_line = crlf

[*.{sh,bash}]
indent_size = 2
